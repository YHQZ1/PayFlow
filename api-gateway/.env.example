# Server
PORT=4000
LOG_LEVEL=info

# Downstream Services
PAYMENT_SERVICE_URL=http://localhost:3000
LEDGER_SERVICE_URL=http://localhost:3001
FRAUD_SERVICE_URL=http://localhost:3002
TENANT_SERVICE_URL=http://localhost:3003
GATEWAY_SERVICE_URL=http://localhost:3004
PAYOUT_SERVICE_URL=http://localhost:3005
RECONCILIATION_SERVICE_URL=http://localhost:3006
NOTIFICATION_SERVICE_URL=http://localhost:3007

# Rate Limiting
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Timeouts (milliseconds)
REQUEST_TIMEOUT_MS=10000
AUTH_TIMEOUT_MS=5000

# Security
INTERNAL_TOKEN_SECRET=payflow-internal-secret-change-this-in-production

# CORS
CORS_ORIGIN=*