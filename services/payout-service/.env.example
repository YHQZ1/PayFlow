# Server
PORT=3005
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://payflow:payflow@localhost:5432/payflow_payouts

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=payout-service-cg

# Services
GATEWAY_SERVICE_URL=http://localhost:3004
LEDGER_SERVICE_URL=http://localhost:3001

# Payout limits (in smallest currency unit, e.g., paise)
MIN_PAYOUT_AMOUNT=100
MAX_PAYOUT_AMOUNT=10000000