# Server
PORT=3002
LOG_LEVEL=info

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=fraud-service-cg

# Fraud Detection Thresholds
FRAUD_VELOCITY_THRESHOLD=5
FRAUD_VELOCITY_WINDOW_SEC=60
FRAUD_LARGE_AMOUNT_THRESHOLD=10000000
FRAUD_FAILURE_THRESHOLD=3
FRAUD_FLAG_THRESHOLD=50